{
  "name": "@beevibe/scheduler",
  "version": "0.0.1",
  "private": true,
  "description": "Beevibe scheduler — claims null-runtime pending sessions as the in-process fallback claimant when no daemon is bound to the agent",
  "license": "Apache-2.0",
  "author": "Zhe Pang",
  "repository": {
    "type": "git",
    "url": "https://github.com/beevibe-ai/beevibe.git",
    "directory": "packages/scheduler"
  },
  "type": "module",
  "main": "./dist/main.js",
  "bin": {
    "beevibe-scheduler": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@beevibe/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/pg": "^8.11.10",
    "dotenv": "^17.4.2"
  }
}
